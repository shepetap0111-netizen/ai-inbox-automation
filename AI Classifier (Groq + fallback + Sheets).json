      "typeVersion": 3.4,
      "position": [
        896,
        -128
      ]
    },
    {
      "parameters": {
        "jsCode": "// Fallback: rule-based классификация по ключевым словам\nconst src = $('Вход (из Merge)').item.json;\nconst text = (src.raw_text || '').toLowerCase();\n\nfunction has(arr) { return arr.some(w => text.includes(w)); }\n\nlet category = 'other';\nlet priority = 'low';\nlet sentiment = 'neutral';\n\nif (has(['ошибк','не работает','сломал','срочно','проблем','баг','error','broken'])) {\n  category = 'support'; priority = 'high';\n} else if (has(['куп','цена','стоим','заказ','оплат','тариф','price','buy'])) {\n  category = 'sales'; priority = 'medium';\n} else if (has(['выигр','приз','казино','крипт','viagra','free money','лохотрон'])) {\n  category = 'spam'; priority = 'low';\n}\n\nif (has(['спасибо','отлично','супер','благодар','круто'])) sentiment = 'positive';\nelse if (has(['плохо','ужас','злю','недоволен','отврат','верните деньги'])) sentiment = 'negative';\n\nconst summary = (src.raw_text || '').slice(0, 80);\n\nreturn [{ json: {\n  source: src.source,\n  from: src.contact_name,\n  text: src.raw_text,\n  category, priority, sentiment, summary,\n  method: 'rules'\n} }];"
      },
